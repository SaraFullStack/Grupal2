  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: DialogMessages_es
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: es
  m_SharedData: {fileID: 11400000, guid: c0e8876162f544d6b914fa899ab5112c, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 32764846080
    m_Localized: Soy C0D4, un robot que busca entender este bosque.
    m_Metadata:
      m_Items: []
  - m_Id: 9461293056
    m_Localized: "\xBFQui\xE9n eres, brillante extra\xF1o?"
    m_Metadata:
      m_Items: []
  - m_Id: 57586737152
    m_Localized: Este lugar no se entiende, se siente.
    m_Metadata:
      m_Items: []
  - m_Id: 80940621824
    m_Localized: Entonces debo aprender a sentir.
    m_Metadata:
      m_Items: []
  - m_Id: 103539531776
    m_Localized: Camina conmigo sin analizar.
    m_Metadata:
      m_Items: []
  - m_Id: 136435458048
    m_Localized: "Intentar\xE9 no calcular cada paso."
    m_Metadata:
      m_Items: []
  - m_Id: 32678140174336
    m_Localized: "\xBFQu\xE9 hace un robot en mi monta\xF1a, tan lejos de las ciudades
      y sus m\xE1quinas?"
    m_Metadata:
      m_Items: []
  - m_Id: 32782083416064
    m_Localized: "Busco respuestas que no encuentro en mis datos, algo que mis c\xE1lculos
      no pueden explicar."
    m_Metadata:
      m_Items: []
  - m_Id: 32949775884288
    m_Localized: "Aqu\xED las respuestas llegan despacio\u2026 \ny a veces el silencio
      tambi\xE9n ense\xF1a."
    m_Metadata:
      m_Items: []
  - m_Id: 33064313937920
    m_Localized: "Entonces me quedar\xE9 observando contigo, hasta entender lo que
      no puedo procesar."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
